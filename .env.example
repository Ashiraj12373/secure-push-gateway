# ═══════════════════════════════════════════════════════════
#  Secure Push Gateway — Environment Variables
#  Copy to .env and fill in your real values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────
DB_ROOT_PASSWORD=rootpass
DB_USERNAME=spg_user
DB_PASSWORD=spg_pass

# ── JWT (generate a 256-bit random string) ───────────────────
JWT_SECRET=replace_with_a_256_bit_random_secret_key_here_minimum_32_chars

# ── GitHub ────────────────────────────────────────────────────
# The secret you set when creating the GitHub webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# A GitHub PAT with repo:read scope for fetching commit diffs
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ── Gmail SMTP ────────────────────────────────────────────────
# Use an App Password, not your main password
MAIL_USERNAME=your-address@gmail.com
MAIL_PASSWORD=your-app-password-here

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
